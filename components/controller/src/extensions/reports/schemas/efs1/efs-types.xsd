<?xml version="1.0" encoding="UTF-8"?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns="http://ns.efs.ru/VS/EFS/2026-01-01"
	xmlns:ВС2="http://ns.efs.ru/VS/types/2025-01-01" xmlns:УТ2="http://ns.efs.ru/UT/2025-01-01"
	xmlns:ns1="http://www.w3.org/2000/09/xmldsig#" targetNamespace="http://ns.efs.ru/VS/EFS/2026-01-01"
	elementFormDefault="qualified" version="2.0">
	<xs:import namespace="http://ns.efs.ru/UT/2025-01-01" schemaLocation="unif-types.xsd"/>
	<xs:import namespace="http://ns.efs.ru/VS/types/2025-01-01" schemaLocation="vs-types.xsd"/>
	<xs:import namespace="http://www.w3.org/2000/09/xmldsig#"
		schemaLocation="xmldsig.xsd"/>
	<xs:annotation>
		<xs:documentation>Рекомендуемый префикс для пространства имен http://пф.рф/ВС/ЕФС/2022-09-22 - ЕФС</xs:documentation>
	</xs:annotation>
	<xs:complexType name="ТипСтрахователь">
		<xs:annotation>
			<xs:documentation>Данные о страхователе</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="РегНомер" type="ТипРегНомерОбщ">
				<xs:annotation>
					<xs:documentation>Действующий регистрационный номер страхователя</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Наименование" type="УТ2:ТипНепустаяСтрока">
				<xs:annotation>
					<xs:documentation>Полное или сокращенное (при наличии) наименование организации, обособленного подразделения/фамилия, имя, отчество (последнее при наличии) индивидуального предпринимателя, физического лица</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element ref="УТ2:ИНН">
				<xs:annotation>
					<xs:documentation>Идентификационный номер налогоплательщика</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element ref="УТ2:КПП" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Код причины постановки на учет</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ОКФС" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Указывается цифровой код в соответствии с Общероссийским классификатором форм собственности</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="12"/>
						<xs:enumeration value="13"/>
						<xs:enumeration value="14"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ОКОГУ" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Указывается цифровой код, присвоенный организации в соответствии с Общероссийским классификатором органов государственной власти и управления</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:pattern value="\d{7}"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ОКПО" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Указывается цифровой код, присвоенный организации в соответствии с Общероссийским классификатором предприятий и организаций</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:pattern value="\d{8}"/>
						<xs:pattern value="\d{10}"/>
						<xs:pattern value="\d{14}"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element ref="УТ2:КодПоОКВЭД" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Код по Общероссийскому классификатору видов экономической деятельности</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:choice>
				<xs:element name="ОГРН" type="УТ2:ТипКодЕГРЮЛ">
					<xs:annotation>
						<xs:documentation>Указывается основной государственный регистрационный номер юридического лица. Для иностранной организации реквизит не заполняется</xs:documentation>
					</xs:annotation>
				</xs:element>
				<xs:element name="ОГРНИП" type="УТ2:ТипКодЕГРИП" minOccurs="0">
					<xs:annotation>
						<xs:documentation>Указывается основной государственный регистрационный номер индивидуального предпринимателя. Для физического лица, занимающегося частной практикой (адвокат, нотариус и др.) реквизит не заполняется</xs:documentation>
					</xs:annotation>
				</xs:element>
			</xs:choice>
			<xs:element ref="УТ2:Телефон" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Указывается городской или мобильный номер телефона страхователя с кодом города или оператора сотовой связи соответственно</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element ref="УТ2:АдресЭлПочты" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Указывается адрес электронной почты страхователя</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="КодКатСтрахФЛ" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Код категории страхователя - физического лица. Возможные значения:
						ИП01 - индивидуальные предприниматели;
						ИП02 - главы крестьянских (фермерских) хозяйств, зарегистрированные в качестве индивидуальных предпринимателей;
						ФЛ01 - физические лица, производящие выплаты физическим лицам;
						ФЛ02 - адвокаты;
						ФЛ03 - нотариусы, занимающиеся частной практикой;
						ФЛ04 - арбитражные управляющие;
						ФЛ05 - патентные поверенные;
						ФЛ06 - оценщики;
						ФЛ07 - медиаторы
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="ИП01"/>
						<xs:enumeration value="ИП02"/>
						<xs:enumeration value="ФЛ01"/>
						<xs:enumeration value="ФЛ02"/>
						<xs:enumeration value="ФЛ03"/>
						<xs:enumeration value="ФЛ04"/>
						<xs:enumeration value="ФЛ05"/>
						<xs:enumeration value="ФЛ06"/>
						<xs:enumeration value="ФЛ07"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ТипТД">
		<xs:annotation>
			<xs:documentation>Сведения о мероприятиях кадрового учета</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="UUID" type="УТ2:ТипGUID">
				<xs:annotation>
					<xs:documentation>UUID мероприятия</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Дата">
				<xs:annotation>
					<xs:documentation>Дата проведения мероприятия</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:date">
						<xs:pattern value="\d{4}-\d{2}-\d{2}"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Вид">
				<xs:annotation>
					<xs:documentation>Вид мероприятия. Возможные значения:
1 - ПРИЕМ;
2 - ПЕРЕВОД;
3 - ПЕРЕИМЕНОВАНИЕ;
4 - УСТАНОВЛЕНИЕ (ПРИСВОЕНИЕ);
5 - УВОЛЬНЕНИЕ;
6 - ЗАПРЕТ ЗАНИМАТЬ ДОЛЖНОСТЬ (ВИД ДЕЯТЕЛЬНОСТИ);
7 -  ПРИОСТАНОВЛЕНИЕ;
8 -  ВОЗОБНОВЛЕНИЕ;
9 - НАЧАЛО ДОГОВОРА ГПХ;
10 - ОКОНЧАНИЕ ДОГОВОРА ГПХ</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:positiveInteger">
						<xs:minInclusive value="1"/>
						<xs:maxInclusive value="10"/>
						<xs:pattern value="[1-9]\d*"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="РаботаКС" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Сведения о работе в районах Крайнего Севера/работе в местностях, приравненных к районам Крайнего Севера</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="РКС"/>
						<xs:enumeration value="МКС"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="Сведения" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Иные сведения о мероприятии</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Должность" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Должность, профессия, специальность, квалификация</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ЯвляетсяСовместителем" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Совместитель. Возможные значения:
«0» - бессрочный трудовой договор;
«0.1» - срочный трудовой договор, заключаемый на срок до 6 месяцев;
«0.2» - срочный трудовой договор, заключаемый на срок более 6 месяцев;
«1» - трудовой договор по совместительству;
«1.1» - трудовой договор по совместительству, заключаемый на срок до 6 месяцев;
«1.2» - трудовой договор по совместительству, заключаемый на срок более 6 месяцев.</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="0"/>
						<xs:enumeration value="0.1"/>
						<xs:enumeration value="0.2"/>
						<xs:enumeration value="1"/>
						<xs:enumeration value="1.1"/>
						<xs:enumeration value="1.2"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ВидПР" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Конкретный вид поручаемой работы</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="СтруктурноеПодразделение" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Структурное подразделение, в которое принят сотрудник</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="КодВФ" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Код выполняемой функции</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:pattern value="\d{2}\.\d{3}\-[а-я|А-Я|a-z|A-Z]\-\d{1}"/>
						<xs:pattern value="ДГПХ|ДАВТ|ДОИП|ИЗЛД|ЛДПИ|ДГПХФЛНС|ДАВТФЛНС|ОСОБ|ДИСТ|НЕПД|НЕПН|НДОМ"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="КодВФпоОКЗ" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Указывается кодовое обозначение занятия, соответствующее занимаемой должности (профессии), виду трудовой деятельности, осуществляемой на рабочем месте при исполнении трудовых функций (работ, обязанностей) в соответствии с Общероссийским классификатором занятий.
						Заполняется обязательно для кадровых мероприятий со значением «ПРИЕМ», «ПЕРЕВОД», «УСТАНОВЛЕНИЕ (ПРИСВОЕНИЕ)», «УВОЛЬНЕНИЕ», «ПРИОСТАНОВЛЕНИЕ», «ВОЗОБНОВЛЕНИЕ», «НАЧАЛО ДОГОВОРА ГПХ» или «ОКОНЧАНИЕ ДОГОВОРА ГПХ»
					</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:pattern value="\d{4}\.\d{1}"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ОснованиеУвольнения" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Сведения о нормативном документе, на основании которого проведено увольнение</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element ref="КодПричиныУвольнения"/>
						<xs:element name="НормативныйДокумент" type="УТ2:ТипНепустаяСтрока"
							minOccurs="0">
							<xs:annotation>
								<xs:documentation>Наименование нормативного документа</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Статья" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Номер статьи нормативного правого акта Российской Федерации, в соответствии с которым проведено расторжение трудового договора</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Часть" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Часть статьи нормативного правого акта Российской Федерации, в соответствии с которым проведено расторжение трудового договора</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Пункт" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Пункт статьи нормативного правого акта Российской Федерации, в соответствии с которым проведено расторжение трудового договора</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Подпункт" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Подпункт статьи нормативного правого акта Российской Федерации, в соответствии с которым проведено расторжение трудового договора</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Абзац" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
							<xs:annotation>
								<xs:documentation>Абзац статьи нормативного правого акта Российской Федерации, в соответствии с которым проведено расторжение трудового договора</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element name="Причина" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Причина увольнения</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ДатаС" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Дата начала</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ДатаПо" type="xs:date" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Дата окончания</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Основание" maxOccurs="2">
				<xs:annotation>
					<xs:documentation>Сведения о документе-основании для мероприятия</xs:documentation>
				</xs:annotation>
				<xs:complexType>
					<xs:sequence>
						<xs:element name="Наименование" type="УТ2:ТипНепустаяСтрока">
							<xs:annotation>
								<xs:documentation>Наименование документа-основания</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Дата">
							<xs:annotation>
								<xs:documentation>Дата документа-основания</xs:documentation>
							</xs:annotation>
							<xs:simpleType>
								<xs:restriction base="xs:date">
									<xs:pattern value="\d{4}-\d{2}-\d{2}"/>
								</xs:restriction>
							</xs:simpleType>
						</xs:element>
						<xs:element name="Серия" type="УТ2:ТипНепустаяСтрока" minOccurs="0">
							<xs:annotation>
								<xs:documentation> Серия документа-основания</xs:documentation>
							</xs:annotation>
						</xs:element>
						<xs:element name="Номер" type="УТ2:ТипНепустаяСтрока">
							<xs:annotation>
								<xs:documentation>Номер документа-основания</xs:documentation>
							</xs:annotation>
						</xs:element>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
			<xs:element minOccurs="0" name="РегНомер1" type="ТипРегНомерОбщ">
				<xs:annotation>
					<xs:documentation>Регистрационный номер страхователя, прежний.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element minOccurs="0" name="РегНомер2" type="ТипРегНомерОбщ">
				<xs:annotation>
					<xs:documentation>Регистрационный номер страхователя, новый.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="ТипМероприятиеОтменяемое">
		<xs:annotation>
			<xs:documentation>Сведения об отменяемых мероприятиях кадрового учета</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="UUID" type="УТ2:ТипGUID">
				<xs:annotation>
					<xs:documentation>UUID отменяемого мероприятия</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="ДатаМероприятия">
				<xs:annotation>
					<xs:documentation>Дата мероприятия, подлежащего отмене</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:date">
						<xs:pattern value="\d{4}-\d{2}-\d{2}"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ДатаОтмены" type="xs:date">
				<xs:annotation>
					<xs:documentation>Дата отмены мероприятия</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Вид">
				<xs:annotation>
					<xs:documentation>Вид мероприятия. Возможные значения:
1 - ПРИЕМ;
2 - ПЕРЕВОД;
3 - ПЕРЕИМЕНОВАНИЕ;
4 - УСТАНОВЛЕНИЕ (ПРИСВОЕНИЕ);
5 - УВОЛЬНЕНИЕ;
6 - ЗАПРЕТ ЗАНИМАТЬ ДОЛЖНОСТЬ (ВИД ДЕЯТЕЛЬНОСТИ);
7 -  ПРИОСТАНОВЛЕНИЕ;
8 -  ВОЗОБНОВЛЕНИЕ;
9 - НАЧАЛО ДОГОВОРА ГПХ;
10 - ОКОНЧАНИЕ ДОГОВОРА ГПХ</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:positiveInteger">
						<xs:minInclusive value="1"/>
						<xs:maxInclusive value="10"/>
						<xs:pattern value="[1-9]\d*"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="РаботаКС" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Сведения о работе в районах Крайнего Севера/работе в местностях, приравненных к районам Крайнего Севера</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:string">
						<xs:enumeration value="РКС"/>
						<xs:enumeration value="МКС"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="ЯвляетсяСовместителем" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Совместитель. Возможные значения:
«0» - бессрочный трудовой договор;
«0.1» - срочный трудовой договор, заключаемый на срок до 6 месяцев;
«0.2» - срочный трудовой договор, заключаемый на срок более 6 месяцев;
«1» - трудовой договор по совместительству;
«1.1» - трудовой договор по совместительству, заключаемый на срок до 6 месяцев;
«1.2» - трудовой договор по совместительству, заключаемый на срок более 6 месяцев.</xs:documentation>
				</xs:annotation>
