										<xs:element name="ПерсСвСтрахЛиц" minOccurs="0" maxOccurs="unbounded">
											<xs:annotation>
												<!---*********************************************************************************************************************************************************-->
												<xs:appinfo>
													<sch:pattern name="Присутствие элемента ПрАннулир в зависимости от значения элемента НомКорр">
														<sch:rule context="ПерсСвСтрахЛиц">
															<!-- 20. Контроль  обязательности  присутствия (отсутствия) элемента ПрАннулир в зависимости от значения элемента НомКорр -->
															<sch:assert test="usch:iif( (  (../../@НомКорр)=0  or  (../../@НомКорр)=00  or  (../../@НомКорр)=000  )  ,   count(@ПрАннулир)=0 ,  (  count(@ПрАннулир)=0  or count(@ПрАннулир)!=0  )  )">
																<usch:error code="0400300003" path="@ПрАннулир" value-of-select="count(@ПрАннулир)">Не выполнено условие присутствия (отсутствия) элемента Файл/Документ/РасчетСВ/ПерсСвСтрахЛиц/ПрАннулир при значении элемента НомКорр, равном "<usch:value-of select="../../@НомКорр"/>".</usch:error>
															</sch:assert>
														</sch:rule>
													</sch:pattern>
												</xs:appinfo>
												<!---*********************************************************************************************************************************************************-->
												<!---*********************************************************************************************************************************************************-->
												<xs:appinfo>
													<sch:pattern name="Присутствие элемента СвВыплСВОПС в зависимости от значения элемента ПрАннулир">
														<sch:rule context="ПерсСвСтрахЛиц">
															<!-- 21. Контроль  обязательности  присутствия (отсутствия) элемента  СвВыплСВОПС  в  зависимости  от  значения  ПрАннулир  -->
															<sch:assert test="usch:iif(@ПрАннулир=1, count(СвВыплСВОПС)=0, count(СвВыплСВОПС)!=0 )">
																<usch:error code="0400300003" path="СвВыплСВОПС" value-of-select="@ПрАннулир">Не выполнено условие присутствия (отсутствия) элемента Файл/Документ/РасчетСВ/ПерсСвСтрахЛиц/СвВыплСВОПС при значении элемента ПрАннулир, равном "<usch:value-of select="@ПрАннулир"/>".</usch:error>
															</sch:assert>
														</sch:rule>
													</sch:pattern>
												</xs:appinfo>
												<!---*********************************************************************************************************************************************************-->
												<xs:documentation>Персонифицированные сведения о застрахованных лицах</xs:documentation>
											</xs:annotation>
											<xs:complexType>
												<xs:sequence>
													<xs:element name="ДанФЛПолуч">
														<xs:annotation>
															<!---*************************************************************************************************************************************************************-->
															<xs:appinfo>
																<sch:pattern name="Значение элемента ИННФЛ">
																	<sch:rule context="ДанФЛПолуч">
																		<!-- 22. Контроль значения элемента ИННФЛ -->
																		<sch:assert test="	(substring(@ИННФЛ,3,10)!=1234567890) and (substring(@ИННФЛ,3,10)!=000000000000) and (substring(@ИННФЛ,1,2)!=96) and (substring(@ИННФЛ,1,2)!=98) ">
																			<usch:error code="0400400007" path="@ИННФЛ" value-of-select="@ИННФЛ"> Не выполнено условие к значению элемента Файл/Документ/РасчетСВ/ПерсСвСтрахЛиц/ДанФЛПолуч/ИННФЛ при значении элемента ИННФЛ, равном "<usch:value-of select="@ИННФЛ"/>". </usch:error>
																		</sch:assert>
																	</sch:rule>
																</sch:pattern>
															</xs:appinfo>
															<!---*************************************************************************************************************************************************************-->
															<!---*********************************************************************************************************************************************************-->
															<xs:appinfo>
																<sch:pattern name="Значение года в элементе ДатаРожд меньше значения года в элементе ДатаДок">
																	<sch:rule context="ДанФЛПолуч">
																		<!-- 23. Контроль значения года и месяца в элементе ДатаРожд, которое должно быть меньше значения года и месяца в элементе ДатаДок -->
																		<sch:assert test="usch:iif(  
																    	( substring(@ДатаРожд,4,2) ) &gt;= ( substring(../../../@ДатаДок,4,2) )   ,  
															    		  ( substring(@ДатаРожд,7,4) ) &lt; ( substring(../../../@ДатаДок,7,4) )	 ,  
																		  ( substring(@ДатаРожд,7,4) ) &lt;= ( substring(../../../@ДатаДок,7,4) )   
																		)">
																			<usch:error code="0400400007" path="@ДатаРожд" value-of-select="@ДатаРожд">Не выполнено условие к значению года и месяца в элементе Файл/Документ/РасчетСВ/ПерсСвСтрахЛиц/ДанФЛПолуч/ДатаРожд при значении года и месяца в элементе Файл/Документ/ДатаДок, равном "<usch:value-of select="../../../@ДатаДок"/>". </usch:error>
																		</sch:assert>
																	</sch:rule>
																</sch:pattern>
