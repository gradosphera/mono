# Порт HTTP-сервера релея (за ним nginx+TLS)
PORT=3025

# Общий секрет. Коопы шлют Authorization: Bearer <RELAY_TOKEN>.
# Сгенерировать: openssl rand -hex 32
RELAY_TOKEN=

# SMTP реального почтового сервера (порты должны быть открыты на этом хосте)
SMTP_HOST=
SMTP_PORT=587
# secure: пусто = авто (true для 465, иначе STARTTLS). Можно явно true/false.
SMTP_SECURE=
SMTP_USERNAME=
SMTP_PASSWORD=

# from по умолчанию, если запрос его не прислал
EMAIL_FROM_DEFAULT=

# Опционально: allowlist IP коопов через запятую (defense-in-depth за TLS)
RELAY_IP_ALLOWLIST=

# Опционально: лимит тела запроса
RELAY_BODY_LIMIT=1mb
